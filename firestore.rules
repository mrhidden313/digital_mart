rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is the specific admin
    function isAdmin() {
      return request.auth != null && 
             (request.auth.token.email == 'mrhiddenhacker313@gmail.com');
    }

    // Products & Categories: Everyone can read, only Admin can write
    match /products/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Global Settings: Everyone can read, only Admin can write
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Trash: Only Admin can see and manage trash
    match /trash/{document=**} {
      allow read, write: if isAdmin();
    }

    // Fallback for any other collections: Private by default
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
